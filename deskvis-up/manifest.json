{
	"id": "deskvis-up",
	"name": "DeskVis Up",
	"version": "1.0.0",
	"minNoctaliaVersion": "3.7.2",
	"author": "JustZiad",
	"repository": "https://github.com/noctalia-dev/noctalia-plugins",
	"license": "MIT",
	"description": "Audio visualizer — bars grow upward / wave fills upward. Transparent, follows color scheme.",
	"tags": ["Desktop", "Audio"],
	"entryPoints": {
		"desktopWidget": "DesktopWidget.qml",
		"settings": "Settings.qml"
	},
	"dependencies": {
		"plugins": []
	},
	"metadata": {
		"defaultSettings": {
			"mode": "bars",
			"barCount": 32,
			"fps": 60,
			"sensitivity": 1.5,
			"smoothing": 0.18,
			"useGradient": true,
			"fadeWhenIdle": true,
			"useCustomColors": false,
			"customPrimaryColor": "#6750A4",
			"customSecondaryColor": "#625B71"
		}
	}
}
